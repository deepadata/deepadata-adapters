{
  "name": "deepadata-langchain-adapter",
  "version": "0.1.0",
  "description": "EDM enrichment layer for LangChain — governed emotional schema for any memory type",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "langchain",
    "edm",
    "emotional-data-model",
    "deepadata",
    "memory",
    "ai-memory",
    "enrichment",
    "llm"
  ],
  "author": "DeepaData",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepadata/deepadata-adapters.git",
    "directory": "packages/langchain"
  },
  "homepage": "https://github.com/deepadata/deepadata-adapters/tree/main/packages/langchain#readme",
  "bugs": {
    "url": "https://github.com/deepadata/deepadata-adapters/issues"
  },
  "dependencies": {
    "deepadata-edm-sdk": ">=0.6.0-alpha"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "deepadata-ddna-tools": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "deepadata-ddna-tools": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
